@model BookStore.Models.ViewModels.BookDetailViewModel
@inject Microsoft.AspNetCore.Identity.SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager

@{
    ViewData["Title"] = Model.Book.Title;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Books</a></li>
        <li class="breadcrumb-item active">@Model.Book.Title</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-8">
        <h1>@Model.Book.Title</h1>
        <p class="text-muted">Category: @Model.Book.CategoryTitle</p>

        <h5>Authors</h5>
        <ul>
            @foreach (var a in Model.Book.Authors)
            {
                <li><a asp-controller="Author" asp-action="Books" asp-route-slug="@a.Slug">@a.FullName</a></li>
            }
        </ul>

        <h5>Description</h5>
        <p>@Model.Book.Description</p>

        <p><strong>Pages:</strong> @Model.Book.PageCount</p>

        @if (SignInManager.IsSignedIn(User))
        {
            <a asp-action="Download" asp-route-id="@Model.Book.Id" class="btn btn-success">Download PDF</a>
        }
        else
        {
            <div class="alert alert-info">Please <a asp-area="Identity" asp-page="/Account/Login">login</a> to download this book.</div>
        }
    </div>

    <div class="col-md-4">
        @if (Model.Book.Keywords.Count != 0)
        {
            <h5>Keywords</h5>
            <div>
                @foreach (var kw in Model.Book.Keywords)
                {
                    <span class="badge bg-secondary me-1">@kw</span>
                }
            </div>
        }

        @if (Model.RelatedBooks.Count != 0)
        {
            <h5 class="mt-4">Related Books</h5>
            <ul class="list-group">
                @foreach (var r in Model.RelatedBooks)
                {
                    <li class="list-group-item">
                        <a asp-action="Detail" asp-route-slug="@r.Slug">@r.Title</a>
                        <small class="text-muted d-block">@r.CategoryTitle</small>
                    </li>
                }
            </ul>
        }
    </div>
</div>
