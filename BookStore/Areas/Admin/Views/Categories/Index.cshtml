@model IEnumerable<Category>
@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-4">Categories</h2>

<form method="post" asp-action="Create" class="row g-2 mb-4">
    <div class="col-md-4"><input name="title" class="form-control" placeholder="Title" required></div>
    <div class="col-md-4"><input name="slug" class="form-control" placeholder="Slug" required></div>
    <div class="col-auto"><button class="btn btn-primary">Add</button></div>
</form>

<table class="table table-dark table-striped align-middle">
    <thead><tr><th>Title</th><th>Slug</th><th></th></tr></thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <form method="post" asp-action="Edit">
                    <input type="hidden" name="id" value="@c.Id">
                    <td><input name="title" value="@c.Title" class="form-control form-control-sm"></td>
                    <td><input name="slug" value="@c.Slug" class="form-control form-control-sm"></td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary">Save</button>
                        <button type="submit" formaction="@Url.Action("Delete")" formmethod="post" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete?')">Delete</button>
                    </td>
                </form>
            </tr>
        }
    </tbody>
</table>
