@model AdminBookViewModel
@{
    ViewData["Title"] = "Edit Book";
}

<h2 class="mb-4">Edit Book</h2>
<form method="post" class="row g-3">
    <input asp-for="Id" type="hidden">
    <div class="col-md-8">
        <label class="form-label">Title</label>
        <input asp-for="Title" class="form-control" required>
    </div>
    <div class="col-md-4">
        <label class="form-label">Slug</label>
        <input asp-for="Slug" class="form-control" readonly class="form-control-plaintext">
    </div>
    <div class="col-12">
        <label class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
    </div>
    <div class="col-md-3">
        <label class="form-label">Pages</label>
        <input asp-for="PageCount" class="form-control" type="number" required>
    </div>
    <div class="col-md-3">
        <label class="form-label">Category</label>
        <select asp-for="CategoryId" class="form-select" required>
            <option value="">-- Select --</option>
            @foreach (var c in Model.AllCategories)
            {
                <option value="@c.Id">@c.Title</option>
            }
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">File Path</label>
        <input asp-for="FilePath" class="form-control" placeholder="/uploads/sample.pdf">
    </div>
    <div class="col-md-6">
        <label class="form-label">Authors</label>
        <div class="border rounded p-2" style="max-height:200px;overflow-y:auto;background:rgba(255,255,255,0.03);">
            @foreach (var a in Model.AllAuthors)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="AuthorIds" value="@a.Id" id="author_@a.Id" @(Model.AuthorIds.Contains(a.Id)?"checked":"")>
                    <label class="form-check-label" for="author_@a.Id">@a.FullName</label>
                </div>
            }
        </div>
    </div>
    <div class="col-md-6">
        <label class="form-label">Keywords</label>
        <div class="border rounded p-2" style="max-height:200px;overflow-y:auto;background:rgba(255,255,255,0.03);">
            @foreach (var k in Model.AllKeywords)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="KeywordIds" value="@k.Id" id="kw_@k.Id" @(Model.KeywordIds.Contains(k.Id)?"checked":"")>
                    <label class="form-check-label" for="kw_@k.Id">@k.Word</label>
                </div>
            }
        </div>
    </div>
    <div class="col-12">
        <label class="form-label">Related Books</label>
        <div class="border rounded p-2" style="max-height:150px;overflow-y:auto;background:rgba(255,255,255,0.03);">
            @foreach (var b in Model.AllBooks)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="RelatedBookIds" value="@b.Id" id="book_@b.Id" @(Model.RelatedBookIds.Contains(b.Id)?"checked":"")>
                    <label class="form-check-label" for="book_@b.Id">@b.Title</label>
                </div>
            }
        </div>
    </div>
    <div class="col-12">
        <button class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
